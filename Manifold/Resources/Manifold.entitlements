<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	    Phase 0 entitlements. Match the DotZap baseline:

	      - Sandbox OFF, per BRIEF.md "Sandboxing: None — direct distribution
	        gives full IOKit access" and DECISIONS.md D10.
	      - JIT OFF — Sparkle does not require it as of 2.6.x; flip to true
	        only if a future Sparkle release demands it (DECISIONS.md D5).

	    The App Group `group.com.Loofa.Manifold` is *not* declared here yet.
	    Adding App Groups to the entitlements file requires a provisioning
	    profile, which breaks the ad-hoc signing flow (DECISIONS.md D11)
	    that the build pipeline relies on. The App Group is added in Phase 13
	    when the widget extension actually needs to read the snapshot file.
	    Documented as a Phase-0 deviation in BUILD_LOG.md.
	-->
	<key>com.apple.security.app-sandbox</key>
	<false/>
	<key>com.apple.security.cs.allow-jit</key>
	<false/>
</dict>
</plist>
