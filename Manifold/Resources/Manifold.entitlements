<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	    Phase 13 entitlements:

	      - Sandbox OFF, per BRIEF.md "Sandboxing: None — direct
	        distribution gives full IOKit access" and DECISIONS.md D10.
	      - JIT OFF — Sparkle does not require it as of 2.6.x; flip to
	        true only if a future Sparkle release demands it
	        (DECISIONS.md D5).
	      - App Group declaration intentionally OMITTED. Adding the
	        `com.apple.security.application-groups` entitlement requires
	        a provisioning profile, which breaks the ad-hoc signing flow
	        per DECISIONS.md D11. Phase 13 confirmed this attempt fails
	        with `requires a provisioning profile`. Both processes are
	        unsandboxed (this entitlement file + ManifoldWidget's), so
	        they read/write the same path under
	        `~/Library/Application Support/com.Loofa.Manifold/snapshot.json`
	        directly — same trick Phase 10 used for the GRDB database.
	        Documented as a Phase 13 deviation; revisit only if Brandon
	        switches to a developer-account-signed distribution.
	  -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
	<key>com.apple.security.cs.allow-jit</key>
	<false/>
</dict>
</plist>
