<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundleDisplayName</key>
	<string>Manifold</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>0.1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSMinimumSystemVersion</key>
	<string>$(MACOSX_DEPLOYMENT_TARGET)</string>
	<key>NSHumanReadableCopyright</key>
	<string>Copyright © 2026 Brandon Villar. Licensed under GPL-3.0.</string>
	<key>NSPrincipalClass</key>
	<string>NSApplication</string>
	<key>NSSupportsAutomaticTermination</key>
	<true/>
	<key>NSSupportsSuddenTermination</key>
	<true/>
	<!--
	    Phase 16 Sparkle integration.
	      - SUFeedURL: GitHub-hosted appcast.xml (SPEC §15).
	        build-dmg.sh re-writes this on every release so a fork
	        can override; the value here is the dev default so
	        Sparkle can be exercised from a normal Xcode build
	        without running the full DMG pipeline.
	      - SUPublicEDKey: the public half of the EdDSA pair whose
	        private key lives in `keyfile.txt` (gitignored).
	        build-dmg.sh re-writes this too; the value here matches
	        the build script's hard-coded production key so dev
	        builds can validate signed appcast items.
	      - SUEnableInstallerLauncherService /
	        SUEnableDownloaderService FALSE because Manifold is
	        unsandboxed (DECISIONS.md D10) and Sparkle's XPC
	        service helpers aren't required outside the sandbox.
	  -->
	<key>SUFeedURL</key>
	<string>https://raw.githubusercontent.com/Foiler25/Manifold/main/appcast.xml</string>
	<key>SUPublicEDKey</key>
	<string>xHtrtfBbFRxLC+T4BXzw64fpQw1EvpeoKiTRpT48CFk=</string>
	<key>SUEnableInstallerLauncherService</key>
	<false/>
	<key>SUEnableDownloaderService</key>
	<false/>
</dict>
</plist>
