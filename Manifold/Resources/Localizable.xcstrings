    },
    "window.battery.info.health.title" : {
      "extractionState" : "manual",
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "About Battery Health" } } }
    },
    "window.battery.info.health.body" : {
      "extractionState" : "manual",
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Health is the ratio of your battery's current full-charge capacity to its original design capacity. A factory-fresh battery reads 100%; one that has lost 22% of its capacity reads 78%. Health declines slowly over time and with charge cycles." } } }
    },
    "window.battery.info.condition.title" : {
      "extractionState" : "manual",
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Condition Bands" } } }
    },
    "window.battery.info.condition.body" : {
      "extractionState" : "manual",
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Excellent: 90% or above. Good: 80–89%. Fair: 70–79%. Poor: 60–69%. Very Poor: below 60%. Apple recommends a service appointment when condition reaches Poor." } } }
    },
    "window.battery.info.temperature.title" : {
      "extractionState" : "manual",
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "About Battery Temperature" } } }
    },
    "window.battery.info.temperature.body" : {
      "extractionState" : "manual",
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Optimal operating range is 0–35°C. Sustained operation above 40°C can accelerate health decline. The reading shown is the battery cell temperature reported by the SMC, not the case or CPU temperature." } } }
    },
    "window.battery.info.power.title" : {
      "extractionState" : "manual",
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "About Power & Current" } } }
    },
    "window.battery.info.power.body" : {
      "extractionState" : "manual",
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Current is signed: positive values mean the battery is gaining charge; negative values mean it is supplying power. Power is the absolute product of voltage and current. Manifold uses the smoothed Amperage reading to keep the value stable; a fast-changing 'instant' reading would jitter unhelpfully." } } }
    },
    "window.battery.info.capacity.title" : {
      "extractionState" : "manual",
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "About Capacity" } } }
    },
    "window.battery.info.capacity.body" : {
      "extractionState" : "manual",
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Remaining is the live charge in milliamp-hours. Full Charge is the maximum charge your battery can currently hold (this declines with age — the percentage shows the ratio against design). Design Capacity is the manufacturer's original rating and stays constant for the life of the battery." } } }
    },
    "window.battery.empty.title" : {
      "extractionState" : "manual",
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "No battery detected" } } }
    },
    "window.battery.empty.subtitle" : {
