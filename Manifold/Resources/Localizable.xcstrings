    "settings.menubar.batteryItem.detail" : {
      "extractionState" : "manual",
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Adds a second menu bar item showing the current charge percentage. On desktop Macs (no internal battery) this toggle has no effect — the item is never installed." } } }
    },
    "settings.menubar.sampleRate.title" : {
      "extractionState" : "manual",
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Live data refresh" } } }
    },
    "settings.menubar.sampleRate.detail" : {
      "extractionState" : "manual",
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Controls how often Manifold refreshes the secondary battery readouts (temperature, voltage, cycle count, current, power) shown in the Battery tab. Percent, charging state, and plug / unplug events are pushed instantly by macOS regardless of this rate. Lower values save power; the kernel rarely publishes new values faster than 1 Hz, so 1.0 Hz is a sensible default." } } }
    },
    "settings.menubar.alerts.section.master" : {
      "comment" : "Phase 19 Settings — battery alerts master section header.",
      "extractionState" : "manual",
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Battery alerts" } } }
    },
