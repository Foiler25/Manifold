<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	    Phase 13 widget entitlements: matches Manifold.entitlements.
	    Sandbox stays off (DECISIONS.md D10) and JIT stays off (D5).
	    App Group entitlement intentionally OMITTED — adding it
	    requires a provisioning profile and breaks the ad-hoc signing
	    flow (DECISIONS.md D11). Both Manifold and ManifoldWidget run
	    unsandboxed as the user's uid, so the widget reads the
	    snapshot directly from
	    `~/Library/Application Support/com.Loofa.Manifold/snapshot.json`
	    written by the host app. Same trick Phase 10 used for the
	    GRDB database. Documented as a Phase 13 deviation.
	-->
	<!--
	    Phase 16 F8 closure (mirror of Manifold.entitlements):
	    disable library validation so the embedded ad-hoc-signed
	    `ManifoldKit.framework` loads under hardened runtime. The
	    widget extension also embeds Sparkle indirectly via the
	    host app linkage; same constraint applies.
	-->
	<key>com.apple.security.app-sandbox</key>
	<false/>
	<key>com.apple.security.cs.allow-jit</key>
	<false/>
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
</dict>
</plist>
